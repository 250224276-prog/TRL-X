/* 隐藏滚动条 */
::-webkit-scrollbar { width: 0; height: 0; color: transparent; display: none; }
page { background: #000000; color: #FFFFFF; font-family: 'Inter', sans-serif; }

.list-page { height: 100vh; display: flex; flex-direction: column; overflow: hidden; box-sizing: border-box; }

.header { padding: 100rpx 40rpx 40rpx; display: flex; align-items: center; border-bottom: 2rpx solid rgba(255,255,255,0.1); }
.back-btn { width: 40rpx; height: 40rpx; display: flex; align-items: center; }
.arrow-left { width: 18rpx; height: 18rpx; border-left: 4rpx solid #FFF; border-bottom: 4rpx solid #FFF; transform: rotate(45deg); }
.title { font-size: 40rpx; font-weight: 700; margin-left: 20rpx; }

.race-scroll { flex: 1; height: 0; padding: 40rpx; box-sizing: border-box; }

.race-card { 
  background: rgba(255,255,255,0.05); 
  border-radius: 24rpx; 
  padding: 30rpx; 
  margin-bottom: 30rpx; 
  position: relative; 
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
/* 点击时的反馈效果 */
.race-card:active { border-color: #FF9811; background: rgba(255, 152, 17, 0.05); }

.rc-name { font-size: 34rpx; font-weight: 700; display: block; margin-bottom: 12rpx; padding-right: 120rpx;}
.rc-date { font-size: 24rpx; color: #888; display: block; margin-bottom: 24rpx; }

.rc-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 8rpx; border: 2rpx solid; background: rgba(255,255,255,0.05); font-weight: 700;}

.edit-hint { position: absolute; right: 30rpx; top: 30rpx; font-size: 22rpx; color: #FF9811; font-weight: 700; background: rgba(255, 152, 17, 0.1); padding: 8rpx 16rpx; border-radius: 20rpx;}

/* ✨ 删除按钮样式 */
.delete-btn {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  font-size: 24rpx;
  color: #E53935;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(229, 57, 53, 0.1);
  font-weight: 700;
  z-index: 2; /* 确保图层在最上面不被遮挡 */
}
.delete-btn:active {
  background: rgba(229, 57, 53, 0.25);
}

.empty-state { text-align: center; color: #555; font-size: 28rpx; margin-top: 200rpx; }
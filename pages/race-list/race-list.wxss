/* 全局背景 */
page {
  background-color: #000000;
  height: 100vh;
}
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  color: #FFFFFF;
}

/* 顶部自定义导航 */
.custom-nav {
  display: flex;
  align-items: center;
  height: 88rpx; 
  padding-left: 30rpx;
  position: relative;
  flex-shrink: 0;
}
.back-btn-box {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  position: absolute;
  left: 30rpx;
  z-index: 10;
}
.back-btn {
  width: 20rpx;
  height: 20rpx;
  border-bottom: 4rpx solid #FFFFFF;
  border-left: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
}
.nav-title {
  width: 100%;
  text-align: center;
  font-family: 'PingFang SC', sans-serif;
  font-weight: 600;
  font-size: 34rpx;
}

/* 搜索与筛选控制栏 */
.control-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  gap: 20rpx;
  flex-shrink: 0;
  margin-top: 10rpx;
}

.search-box {
  flex: 1;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
  height: 100%;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #FFFFFF;
}

.ph-color {
  color: rgba(255, 255, 255, 0.3);
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  padding: 0 30rpx;
  background: rgba(255, 152, 17, 0.15); 
  border-radius: 36rpx;
  color: #FF9811;
  font-size: 28rpx;
  font-weight: 600;
  position: relative;
}

.filter-dot {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 12rpx;
  height: 12rpx;
  background-color: #FF4D4F;
  border-radius: 50%;
}

/* 列表滚动区 */
.list-scroll {
  flex: 1;
  height: 0;
}
.list-container {
  padding: 20rpx 40rpx 0 40rpx;
  display: flex;
  flex-direction: column;
}

/* ✨ 焕新月份标题 */
.month-header {
  display: flex;
  align-items: baseline; 
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}
.mh-month {
  font-family: 'Inter', sans-serif;
  font-size: 48rpx; /* ✨ 从 40rpx 放大到 48rpx，更醒目 */
  font-weight: 800;
  color: #FFFFFF;
  margin-right: 16rpx;
}
.mh-year {
  font-family: 'Inter', sans-serif;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.3); 
  margin-right: 24rpx;
}
.month-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.1);
  position: relative;
  top: -6rpx; 
}

/* 赛事卡片 */
.race-card {
  background: #1C1C1E; 
  border-radius: 32rpx; 
  padding: 28rpx 32rpx; 
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.race-card:active {
  transform: scale(0.98); 
  opacity: 0.8;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  padding-right: 20rpx; 
}

.race-name {
  font-family: 'Inter', 'PingFang SC', sans-serif;
  font-weight: 700;
  font-size: 32rpx;
  color: #FF9811;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.itra-tag {
  background: rgba(255, 255, 255, 0.1);
  color: #FF9811;
  font-size: 18rpx;
  font-weight: 800;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0; 
}

.arrow-right {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid rgba(255,255,255,0.4);
  border-right: 3rpx solid rgba(255,255,255,0.4);
  transform: rotate(45deg);
  flex-shrink: 0;
}

.race-date {
  font-family: 'Inter', 'PingFang SC', sans-serif;
  font-size: 22rpx; 
  font-weight: 400;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
  margin-bottom: 20rpx; 
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx; 
  flex: 1;
}

.dist-tag {
  background: rgba(255, 255, 255, 0.08); 
  font-family: 'Inter', sans-serif;
  font-size: 18rpx; 
  font-weight: 600; 
  padding: 4rpx 14rpx; 
  border-radius: 16rpx;
}

.race-location {
  font-family: 'PingFang SC', sans-serif;
  font-size: 18rpx; 
  font-weight: 400;
  color: rgba(255, 255, 255, 0.4); 
  text-align: right;
  line-height: 1.4;
  max-width: 45%;
  white-space: pre-line; 
  flex-shrink: 0;
  margin-left: 20rpx; 
}

.empty-state { text-align: center; padding: 100rpx 0; }
.empty-text { font-size: 28rpx; color: rgba(255,255,255,0.4); }


/* ========================================== */
/* 高级筛选面板 (苹果 iOS 风格) */
/* ========================================== */
.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  z-index: 900;
}

.filter-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  height: 80vh;
  background: rgba(28, 28, 30, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow: 0 -10rpx 30rpx rgba(0,0,0,0.5);
}
.filter-panel.show {
  transform: translateY(0);
}

.panel-drag-handle {
  width: 72rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  margin: 16rpx auto 0 auto;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx 30rpx 40rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.panel-btn-left {
  font-size: 32rpx;
  color: rgba(255,255,255,0.5);
  padding: 10rpx 0;
}
.panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.panel-btn-right {
  font-size: 32rpx;
  color: #FF9811;
  font-weight: 600;
  padding: 10rpx 0;
}

.panel-scroll {
  flex: 1;
  height: 0;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.filter-section {
  margin-top: 50rpx;
  margin-bottom: 10rpx;
}
.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
  text-transform: uppercase;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.filter-tag {
  background: rgba(118, 118, 128, 0.24); 
  padding: 16rpx 32rpx;
  border-radius: 16rpx; 
  font-size: 26rpx;
  color: #FFFFFF;
  transition: all 0.2s;
}
.filter-tag.active {
  background: rgba(255, 152, 17, 0.15);
  color: #FF9811;
  font-weight: 600;
}

/* ✨ 修复地区选择框文字漂移：去掉 line-height，让 Flex 绝对居中接管 */
.ios-picker-box {
  background: rgba(118, 118, 128, 0.24);
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center; 
  padding: 0 30rpx;
  box-sizing: border-box;
  width: 100%;
}
.ph-text, .selected-text {
  font-size: 28rpx; 
  line-height: 0rpx;/* 关键修复点：重置行高 */
}
.ph-text { color: rgba(255, 255, 255, 0.3); }
.selected-text { color: #FFFFFF; font-weight: 500; }

.date-range-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.date-picker {
  flex: 1;
  background: rgba(118, 118, 128, 0.24);
  height: 70rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
  min-width: 260rpx;
}
.date-picker.has-val {
  color: #FFFFFF;
  font-weight: 500;
}
.date-separator {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}
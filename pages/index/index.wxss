/* ========================================== */
/* 外层锁死且设定为 Flex 布局 */
/* ========================================== */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========================================== */
/* 全局基础布局 */
/* ========================================== */
.container {
  flex: 1;
  height: 0;
  width: 100%;
  background-color: #000000;
  padding: 60rpx 40rpx 200rpx 40rpx;
  box-sizing: border-box;
  color: #FFFFFF;
}

/* ========================================== */
/* 头部区域：未连接状态 */
/* ========================================== */
.header-section {
  display: flex;
  align-items: center;
  margin-bottom: 80rpx;
}
.title-large {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 70rpx; 
}
.arrow-right {
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid rgba(255, 255, 255, 0.6);
  border-right: 4rpx solid rgba(255, 255, 255, 0.6);
  transform: rotate(45deg);
  margin-left: 20rpx;
}

/* ========================================== */
/* 头部区域：已连接状态 UI */
/* ========================================== */
.header-section-connected {
  display: flex;
  flex-direction: column;
  margin-bottom: 80rpx;
}
.device-title-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.connected-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 70rpx;
  line-height: 80rpx; 
  white-space: pre-line; 
}
.polygon-arrow {
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 16rpx solid rgba(255, 255, 255, 0.6);
  margin-left: 30rpx;
  margin-top: 30rpx;
}

.status-tags {
  display: flex;
  gap: 20rpx;
}
.status-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
}

.icon-dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.dot-blue { background: #209BFF; }
.dot-green { background: #36E153; }
.dot-orange { background: #FF9811; }

.pill-text {
  font-family: 'PingFang HK', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  opacity: 0.8;
}
.text-blue { color: #209BFF; }
.text-green { color: #36E153; }
.text-orange { color: #FF9811; }

/* ========================================== */
/* 列表区块基础样式 */
/* ========================================== */
.list-section {
  margin-bottom: 60rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center; 
  margin-bottom: 30rpx;
}
.section-title {
  font-family: 'Hiragino Sans GB', sans-serif;
  font-weight: 600;
  font-size: 44rpx; 
}
.view-more {
  font-size: 30rpx;
  color: rgba(54, 225, 83, 0.6); 
  font-weight: 500;
}

.empty-card {
  height: 150rpx;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 56rpx; 
  display: flex;
  justify-content: center;
  align-items: center;
}
.empty-text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 36rpx;
  color: #FFFFFF;
  opacity: 0.6;
}

/* ========================================== */
/* 已导入的比赛与计划专属 UI */
/* ========================================== */
.my-plan-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 40rpx;
  padding: 8rpx 36rpx; 
  box-sizing: border-box;
}

.plan-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0; 
  position: relative;
}

.plan-info-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx; 
  flex: 1; 
  overflow: hidden; 
  padding-right: 20rpx;
}

.plan-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx; 
  width: 100%;
}

.plan-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 28rpx; 
  color: #FFFFFF;
  white-space: nowrap;
  overflow: hidden; 
  text-overflow: ellipsis; 
  flex-shrink: 1; 
}

/* ✨ 修复了写死的绿色，现由 JS 动态写入 Style 控制 */
.plan-group-tag {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx; 
  padding: 2rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  font-family: 'Inter', sans-serif;
  font-size: 16rpx; 
  font-weight: 600;
  line-height: 1;
  flex-shrink: 0;
}

.plan-date {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 2rpx;
}

.plan-info-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx; 
  margin-right: 30rpx;
  flex-shrink: 0;
}

.plan-time {
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  font-size: 26rpx; 
  color: #FFFFFF;
}

.plan-countdown {
  font-family: 'PingFang HK', sans-serif;
  font-weight: 500;
  font-size: 22rpx; 
  color: #36E153; 
  opacity: 0.6;
}

.dark-arrow {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%) rotate(45deg);
  border-color: rgba(255, 255, 255, 0.4) !important; 
}

.plan-divider {
  width: 100%;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* ========================================== */
/* 赛事卡片列表容器 */
/* ========================================== */
.race-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.race-card {
  position: relative; 
  width: 100%;        
  height: 170rpx;     
  background: rgba(255, 255, 255, 0.11);
  border-radius: 40rpx; 
  overflow: hidden;
  transition: all 0.2s ease;
}
.race-card:active {
  background: rgba(255, 255, 255, 0.15); 
}

.card-header {
  position: absolute;
  left: 36rpx;
  top: 24rpx;   
  right: 36rpx; 
  display: flex;
  justify-content: space-between; 
  align-items: center;
}

.name-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.race-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 30rpx; 
  color: #FF9811;
}

.itra-tag {
  font-size: 16rpx; 
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  color: #FF9811; 
  background: rgba(255, 255, 255, 0.1); 
  padding: 4rpx 12rpx; 
  border-radius: 20rpx; 
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  margin-top: 2rpx; 
}

.arrow-right-small {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.4);
  border-right: 3rpx solid rgba(255, 255, 255, 0.4);
  transform: rotate(45deg);
}

.race-date {
  position: absolute;
  left: 36rpx;        
  top: 66rpx;
  font-family: 'PingFang SC', sans-serif;
  font-size: 24rpx; 
  color: rgba(255, 255, 255, 0.5);
  font-weight: 300;
}

.race-location {
  position: absolute;
  right: 36rpx;
  bottom: 24rpx;   
  font-family: 'PingFang SC', sans-serif;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: right;
  line-height: 1.35;
  white-space: pre-line;
}

.tag-container {
  position: absolute;
  left: 36rpx;        
  bottom: 20rpx;   
  display: flex;
  gap: 12rpx;      
}

.distance-tag {
  background: rgba(255, 255, 255, 0.08); 
  border-radius: 20rpx;
  padding: 6rpx 16rpx; 
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.distance-text {
  font-family: 'Inter', sans-serif;
  font-size: 18rpx;
  font-weight: 600; 
  line-height: 1;
}

.load-more-btn {
  width: 100%;
  height: 90rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 10rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s ease;
}

.load-more-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.load-more-btn text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.6);
}

/* ========================================== */
/* 底部自定义导航栏 */
/* ========================================== */
.custom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 166rpx;
  background: #000000;
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  padding-top: 20rpx;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
}

.tab-item:not(.active) .tab-text {
  opacity: 0.5;
}

.tab-item.active .tab-text {
  opacity: 1;
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-family: 'Inter', sans-serif;
  font-size: 18rpx; 
  font-weight: 500;
  color: #FFFFFF;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
  display: none;
}

<view class="container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <view class="arrow-left"></view>
    </view>
    <text class="nav-title">全部计划</text>
  </view>

  <view class="tab-header">
    <view class="tab-item {{currentTab === 'future' ? 'active' : ''}}" bindtap="switchTab" data-tab="future">
      <text>即将参赛</text>
      <view class="tab-line" wx:if="{{currentTab === 'future'}}"></view>
    </view>
    <view class="tab-item {{currentTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">
      <text>历史足迹</text>
      <view class="tab-line" wx:if="{{currentTab === 'history'}}"></view>
    </view>
  </view>

  <scroll-view class="scroll-area" scroll-y="true">
    <view class="list-section" wx:if="{{displayList.length > 0}}">
      
      <block wx:for="{{displayList}}" wx:key="key" wx:for-item="group" wx:for-index="gIndex">
        
        <view class="month-header">
          <text class="mh-month">{{group.monthStr}}</text>
          <text class="mh-year">{{group.yearStr}}</text>
          <view class="month-line"></view>
        </view>

        <view class="my-plan-card">
          <block wx:for="{{group.plans}}" wx:key="_id" wx:for-item="item" wx:for-index="iIndex">
            
            <view class="swipe-item">
              <view class="swipe-wrapper" 
                    style="transform: translateX({{item.slideX || 0}}px);"
                    bindtouchstart="onTouchStart" 
                    bindtouchmove="onTouchMove" 
                    bindtouchend="onTouchEnd" 
                    data-gindex="{{gIndex}}" 
                    data-iindex="{{iIndex}}">
                
                <view class="plan-content">
                  <view class="plan-row" bindtap="goToMyPlan" data-gindex="{{gIndex}}" data-iindex="{{iIndex}}" data-id="{{item._id}}">
                    <view class="plan-info-left">
                      <view class="plan-title-group">
                        <text class="plan-name">{{item.pureRaceName || item.raceName}}</text>
                        <view class="plan-group-tag" wx:if="{{item.groupDist}}" style="color: {{item.groupColor}}; border-color: {{item.groupColor}};">{{item.groupDist}}</view>
                      </view>
                      <text class="plan-date">{{item.raceDate}}</text>
                    </view>
                    <view class="plan-info-right">
                      <text class="plan-time">{{item.displayTime}}</text>
                      <text class="plan-countdown" wx:if="{{currentTab === 'future' && item.daysLeft > 0}}">剩余{{item.daysLeft}}天</text>
                      <text class="plan-countdown" wx:elif="{{currentTab === 'future' && item.daysLeft === 0}}">就是今天</text>
                      <text class="plan-countdown history-text" wx:elif="{{currentTab === 'history'}}">已完赛</text>
                    </view>
                    <view class="arrow-right-small dark-arrow"></view>
                  </view>
                </view>

                <view class="delete-btn" catchtap="deletePlan" data-id="{{item._id}}">
                  <text>删除</text>
                </view>

              </view>
            </view>
            
            <view class="plan-divider" wx:if="{{iIndex < group.plans.length - 1}}"></view>
          </block>
        </view>
      </block>

    </view>

    <view class="empty-state" wx:if="{{displayList.length === 0}}">
      <text class="empty-text">{{currentTab === 'future' ? '暂无即将到来的比赛计划' : '还没有历史足迹哦'}}</text>
    </view>
  </scroll-view>
</view>

page {
  height: 100vh;
  background-color: #000000;
  color: #FFFFFF;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx; 
  padding-left: 30rpx;
  position: relative;
  margin-bottom: 40rpx;
}
.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  left: 20rpx;
  z-index: 10;
}
.arrow-left {
  width: 20rpx;
  height: 20rpx;
  border-bottom: 4rpx solid #FFFFFF;
  border-left: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
}
.nav-title {
  width: 100%;
  text-align: center;
  font-family: 'PingFang SC', sans-serif;
  font-size: 34rpx;
  font-weight: 600;
}

/* Tab 切换栏 */
.tab-header {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 80rpx;
  margin-bottom: 40rpx;
}
.tab-item {
  position: relative;
  font-family: 'PingFang SC', sans-serif;
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.5); 
  padding-bottom: 16rpx;
  transition: all 0.3s ease;
}
.tab-item.active {
  color: #FFFFFF; 
  font-weight: 600;
  font-size: 32rpx;
}
.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #36E153; 
  border-radius: 6rpx;
}
.history-text {
  color: rgba(255, 255, 255, 0.4) !important;
}

/* ========================================== */
/* 列表区域 & 滑动删除核心结构 */
/* ========================================== */
.scroll-area {
  flex: 1;
  height: 0;
  padding: 0 40rpx 100rpx 40rpx;
  box-sizing: border-box;
}

.my-plan-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 40rpx; 
  padding: 8rpx 0; 
  box-sizing: border-box;
  overflow: hidden; 
}

/* 每一行的外层包裹 */
.swipe-item {
  width: 100%;
}

/* 位移控制层 */
.swipe-wrapper {
  display: flex;
  width: 100%; 
  transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* 左侧真实内容区 */
.plan-content {
  width: 100%;
  flex-shrink: 0; 
  padding: 0 36rpx;
  box-sizing: border-box;
}

/* 右侧红色删除按钮区 */
.delete-btn {
  width: 160rpx;
  flex-shrink: 0;
  background-color: #FF4D4F;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn text {
  font-family: 'PingFang SC', sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.plan-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0; 
  position: relative;
}

.plan-info-left { display: flex; flex-direction: column; gap: 6rpx; flex: 1; overflow: hidden; padding-right: 20rpx; }
.plan-title-group { display: flex; align-items: center; gap: 12rpx; width: 100%; }
.plan-name { font-family: 'Inter', sans-serif; font-weight: 700; font-size: 28rpx; color: #FFFFFF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-shrink: 1; }

.plan-group-tag {
  background: rgba(255, 255, 255, 0.08); border-radius: 16rpx; padding: 2rpx 10rpx;
  display: flex; align-items: center; justify-content: center; border: 1rpx solid rgba(255, 255, 255, 0.05);
  font-family: 'Inter', sans-serif; font-size: 16rpx; font-weight: 600; color: #36E153; flex-shrink: 0;
}

.plan-date { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 20rpx; color: rgba(255, 255, 255, 0.4); }

.plan-info-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; margin-right: 30rpx; flex-shrink: 0; }
.plan-time { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 26rpx; color: #FFFFFF; }
.plan-countdown { font-family: 'PingFang HK', sans-serif; font-weight: 500; font-size: 22rpx; color: #36E153; opacity: 0.6; }

.dark-arrow { position: absolute; right: 0; top: 50%; transform: translateY(-50%) rotate(45deg); border-color: rgba(255, 255, 255, 0.4) !important; }
.plan-divider { width: calc(100% - 72rpx); height: 1rpx; background: rgba(255, 255, 255, 0.15); margin: 0 auto; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; margin-top: 200rpx; }
.empty-text { font-family: 'PingFang SC', sans-serif; font-size: 30rpx; color: rgba(255, 255, 255, 0.4); }
/* pages/plan-result/plan-result.wxss */
page {
  background: #000000;
  color: #FFFFFF;
  font-family: 'Inter', sans-serif;
}
.plan-page { width: 100vw; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

/* 头部 */
.header { position: relative; padding: 100rpx 40rpx 40rpx 40rpx; }
.back-btn { width: 40rpx; height: 40rpx; margin-bottom: 30rpx; }
.arrow-left { width: 20rpx; height: 20rpx; border-left: 4rpx solid #FFF; border-bottom: 4rpx solid #FFF; transform: rotate(45deg); }
.race-name { font-weight: 700; font-size: 50rpx; line-height: 60rpx; margin-bottom: 20rpx; }
.total-time { display: inline-block; padding: 10rpx 30rpx; background: rgba(255, 255, 255, 0.15); border-radius: 29rpx; font-weight: 700; font-size: 32rpx; opacity: 0.8; }

/* 列表区 */
.plan-scroll { flex: 1; width: 100%; height: 0; }

.cp-row {
  position: relative;
  height: 160rpx;
  margin: 0 40rpx;
}

.click-mask { position: absolute; left: 0; top: 0; width: 100%; height: 100%; z-index: 1; }

/* 完美垂直居中容器：CP名 + 换装点小标签 */
.cp-name-box {
  position: absolute; left: 0; 
  top: 50%; transform: translateY(-50%);
  width: 120rpx;
  display: flex; flex-direction: column; justify-content: center; align-items: flex-start;
}
.cp-name { font-weight: 700; font-size: 36rpx; }
.dp-tag { font-size: 20rpx; font-weight: 400; color: #FFFFFF; opacity: 0.5; margin-top: 4rpx; }

/* 控制区组 */
.ctrl-group { position: absolute; display: flex; flex-direction: column; align-items: center; z-index: 2; top: 35rpx; }
.pos-move { left: 130rpx; }
.pos-rest { left: 280rpx; }

.ctrl-label { font-weight: 700; font-size: 22rpx; opacity: 0.8; margin-bottom: 10rpx; }
.ctrl-box {
  width: 120rpx; height: 42rpx;
  background: rgba(255, 255, 255, 0.15); border-radius: 21rpx;
  display: flex; align-items: center; justify-content: center;
}
.ctrl-box input { width: 100%; text-align: center; font-weight: 700; font-size: 28rpx; height: 42rpx; min-height: 42rpx; }
.text-orange { color: #FFAA16; }
.text-blue { color: #3284FF; }

/* 海拔图框 */
.vector-51 {
  position: absolute; right: 180rpx; top: 60rpx;
  width: 80rpx; height: 43rpx;
  border: 3rpx solid #FF9849;
  border-radius: 4rpx;
}

/* 数据区 */
.stats {
  position: absolute; right: 0; 
  top: 50%; transform: translateY(-50%);
  text-align: right; width: 160rpx;
}
.dist-val { font-weight: 700; font-size: 38rpx; }
.gain-loss { display: flex; gap: 10rpx; justify-content: flex-end; margin-top: 4rpx; }
.val-up { font-weight: 700; font-size: 24rpx; color: #F94747; }
.val-down { font-weight: 700; font-size: 24rpx; color: #5CF947; }

.row-divider { position: absolute; bottom: 0; left: 0; width: 100%; height: 2rpx; background: rgba(255, 255, 255, 0.2); }

/* ✨ 底部操作栏：随列表滚动，只在最底端显示 */
.bottom-action-bar {
  margin: 60rpx 40rpx 20rpx 40rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.btn {
  width: 310rpx; height: 88rpx;
  border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 700;
}
.btn-save { background: rgba(255, 255, 255, 0.15); color: #FFFFFF; }
.btn-sync { background: #FF9811; color: #000000; box-shadow: 0 8rpx 20rpx rgba(255, 152, 17, 0.3); }
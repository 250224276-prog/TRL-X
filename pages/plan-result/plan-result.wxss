::-webkit-scrollbar { width: 0; height: 0; color: transparent; display: none; }

page { background: #000000; color: #FFFFFF; font-family: 'Inter', sans-serif; }
.plan-page { width: 100vw; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

.top-nav { padding: 100rpx 40rpx 10rpx 40rpx; background: #000000; position: relative; z-index: 60; flex-shrink: 0; }
.back-btn { width: 40rpx; height: 40rpx; padding-bottom: 10rpx;}
.arrow-left { width: 18rpx; height: 18rpx; border-left: 4rpx solid #FFF; border-bottom: 4rpx solid #FFF; transform: rotate(45deg); }

.plan-scroll { flex: 1; width: 100%; height: 0; }

.scroll-top-section { padding: 10rpx 40rpx 20rpx 40rpx; }
.title-group { display: flex; align-items: center; gap: 20rpx; margin-bottom: 10rpx; }
.race-name { font-weight: 700; font-size: 46rpx; margin-bottom: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 500rpx; }
.plan-group-tag { background: rgba(255, 255, 255, 0.08); border-radius: 16rpx; padding: 4rpx 14rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid transparent; font-family: 'Inter', sans-serif; font-size: 20rpx; font-weight: 700; line-height: 1.2; flex-shrink: 0; }

.sticky-and-list-wrapper { position: relative; width: 100%; z-index: 1; }

.sticky-wrapper { position: -webkit-sticky; position: sticky; top: 0; z-index: 50; background: #000000; border-bottom: 2rpx solid rgba(255, 255, 255, 0.1); }

.config-grid-wrapper { padding: 0 40rpx 10rpx 40rpx; }
.config-grid { display: flex; justify-content: space-between; align-items: center; width: 100%; gap: 16rpx; }
.config-item { display: flex; flex-direction: column; align-items: center; flex: 1; min-width: 0; }
.config-label { font-size: 20rpx; color: rgba(255,255,255,0.5); margin-bottom: 8rpx; white-space: nowrap; }
.config-picker { width: 100%; }
.config-capsule { background: rgba(255, 255, 255, 0.15); border-radius: 20rpx; height: 64rpx; width: 100%; display: flex; justify-content: center; align-items: center; box-sizing: border-box; }
.config-capsule text { font-size: 26rpx; font-weight: 700; color: #FFF; white-space: nowrap; }

.list-header-container { width: 100%; padding: 10rpx 0 20rpx 0; }
.list-row-inner { margin: 0 40rpx; position: relative; }
.list-header-container .list-row-inner { height: 60rpx; }

.col-1 { position: absolute; left: 0; width: 120rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.col-2 { position: absolute; left: 130rpx; width: 140rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.col-3 { position: absolute; left: 280rpx; width: 140rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.col-4 { position: absolute; right: 165rpx; width: 90rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.col-5 { position: absolute; right: 0; width: 160rpx; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; align-items: center; justify-content: center; }

.lh-text { font-size: 22rpx; color: rgba(255,255,255,0.5); font-weight: 600; white-space: nowrap; text-align: center;}
.lh-main { font-size: 22rpx; color: rgba(255,255,255,0.5); font-weight: 600; white-space: nowrap; }
.lh-sub { font-size: 18rpx; color: rgba(255,255,255,0.4); margin-top: 2rpx; white-space: nowrap; }

.list-content { width: 100%; position: relative; }

.cp-row { height: 145rpx; }

.cp-name { font-weight: 700; font-size: 36rpx; text-align: center; }
.dp-tag { font-size: 20rpx; opacity: 0.5; margin-top: 4rpx; text-align: center; }
.cutoff-text { font-size: 18rpx; color: rgba(255, 255, 255, 0.4); margin-top: 0rpx; font-family: 'Inter', sans-serif; white-space: nowrap; font-weight: 500; text-align: center;}

.ctrl-box { width: 120rpx; height: 46rpx; background: rgba(255, 255, 255, 0.15); border-radius: 23rpx; display: flex; align-items: center; justify-content: center; z-index: 2;}
.ctrl-box input { width: 100%; text-align: center; font-weight: 700; font-size: 28rpx; }
.sub-label { font-size: 18rpx; color: rgba(255,255,255,0.5); margin-top: 8rpx; font-weight: 500; font-family: 'Inter', sans-serif; white-space: nowrap; }

.elevation-svg { width: 80rpx; height: 43rpx; background-size: 100% 100%; background-repeat: no-repeat; }

.dist-val { font-weight: 700; font-size: 38rpx; text-align: center; }
.gain-loss { display: flex; gap: 10rpx; justify-content: center; width: 100%; margin-top: 4rpx; }

.text-orange, .txt-orange { color: #FFAA16 !important; }
.text-blue, .txt-blue { color: #3284FF !important; }
.text-red, .txt-red { color: #F94747 !important; }
.val-up { font-weight: 700; font-size: 24rpx; color: #F94747; }
.val-down { font-weight: 700; font-size: 24rpx; color: #5CF947; }

.row-divider { position: absolute; bottom: 0; left: 0; width: 100%; height: 2rpx; background: rgba(255, 255, 255, 0.2); }

.bottom-action-bar { margin: 60rpx 40rpx; display: flex; justify-content: space-between; }
.btn { width: 310rpx; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 700; }
.btn-save { background: rgba(255, 255, 255, 0.15); }
.btn-sync { background: #FF9811; color: #000; }

.modal-mask { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 100; backdrop-filter: blur(8px); }
.detail-sheet { position: fixed; left: 0; right: 0; bottom: 0; height: 86vh; background: #1D1D1D; border-radius: 56rpx 56rpx 0 0; z-index: 101; transform: translateY(100%); transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1); display: flex; flex-direction: column; }
.detail-sheet.show { transform: translateY(0); }
.ds-drag-area { width: 100%; padding-top: 20rpx; }
.pull-handle { width: 80rpx; height: 8rpx; background: rgba(255, 255, 255, 0.2); border-radius: 4rpx; margin: 0 auto 0; }
.ds-top-bar { padding: 40rpx 40rpx 20rpx 40rpx; display: flex; justify-content: space-between; align-items: center; }
.ds-close-circle { width: 90rpx; height: 90rpx; background: rgba(217, 217, 217, 0.08); border-radius: 50%; position: relative; }
.ds-cross1, .ds-cross2 { position: absolute; top: 50%; left: 50%; width: 36rpx; height: 4rpx; background: #FFF; border-radius: 2rpx; }
.ds-cross1 { transform: translate(-50%, -50%) rotate(45deg); }
.ds-cross2 { transform: translate(-50%, -50%) rotate(-45deg); }
.ds-total-capsule { background: rgba(255, 255, 255, 0.15); border-radius: 36rpx; padding: 16rpx 36rpx; }
.ds-total-capsule text { font-size: 30rpx; font-weight: 700; color: #FFF; opacity: 0.9;}
.detail-swiper { flex: 1; width: 100%; margin-top: 10rpx;}
.ds-scroll { height: 100%; padding: 0 40rpx; box-sizing: border-box;}
.ds-title-row { display: flex; align-items: baseline; margin-bottom: 24rpx; flex-wrap: wrap;}
.ds-cp-main { font-size: 64rpx; font-weight: 900; line-height: 1; }
.ds-cp-sub { font-size: 22rpx; font-family: 'Hiragino Sans GB', sans-serif; opacity: 0.4; margin-left: 20rpx; }
.ds-title-divider { width: 100%; height: 2rpx; background: rgba(255, 255, 255, 0.1); margin-bottom: 4rpx; }
.ds-stats-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 20rpx; margin-top: 0;}
.ds-stats-left { display: flex; align-items: baseline; gap: 24rpx; }
.ds-dist-large { font-size: 44rpx; font-weight: 700; }
.ds-elev-up { font-size: 30rpx; font-weight: 700; color: #F94747; }
.ds-elev-down { font-size: 30rpx; font-weight: 700; color: #5CF947; }
.ds-stats-right { display: flex; flex-direction: column; align-items: flex-end; }
.ds-cutoff-lbl { font-size: 20rpx; opacity: 0.4; font-family: 'Hiragino Sans GB', sans-serif;}
.ds-cutoff-val { font-size: 26rpx; font-weight: 600; margin-top: 4rpx; }
.ds-chart-area { width: 100%; height: 320rpx; position: relative; box-sizing: border-box; margin-bottom: 30rpx; background: transparent; }
.elev-canvas { width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 10; }
.chart-loading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 24rpx; color: rgba(255,255,255,0.3); }
.ds-grid { margin-bottom: 30rpx; }
.ds-grid-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;}
.ds-grid-cell { flex: 1; display: flex; justify-content: space-between; align-items: center; border-bottom: 2rpx solid rgba(255, 255, 255, 0.1); padding-bottom: 10rpx;}
.ds-grid-gap { width: 60rpx; } 
.ds-cell-lbl { font-size: 18rpx; color: rgba(255,255,255,0.5); font-weight: 500; }
.ds-cell-val { font-size: 22rpx; font-weight: 700; color: #FFF; }
.ds-inputs-row { display: flex; justify-content: space-around; gap: 40rpx; margin-bottom: 30rpx;}
.ds-input-col { display: flex; flex-direction: column; align-items: center; flex: 1; }
.ds-input-lbl { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 16rpx;}
.ds-input-capsule { background: rgba(255, 255, 255, 0.08); border-radius: 40rpx; height: 70rpx; width: 100%; display: flex; justify-content: center; align-items: center;}
.ds-input-capsule input { width: 60rpx; text-align: right; font-size: 30rpx; font-weight: 700; height: 100%; margin-right: 6rpx; margin-left: -20rpx;}
.ds-unit { font-size: 30rpx; font-weight: 700; }
.ds-divider { width: 100%; height: 2rpx; background: rgba(255, 255, 255, 0.1); margin-bottom: 30rpx; }
.ds-memo-wrapper { width: 100%; display: flex; flex-direction: column; align-items: flex-start;}
.ds-memo-box { background: rgba(255, 255, 255, 0.05); border-radius: 32rpx; padding: 30rpx; width: 100%; box-sizing: border-box;}
.ds-memo-box textarea { width: 100%; height: 120rpx; font-size: 24rpx; line-height: 1.5; color: #FFF; }

.share-canvas { position: fixed; left: -9999px; top: -9999px; width: 1080px; height: 2000px; }

.custom-modal-mask { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 200; backdrop-filter: blur(8px); }
.trl-modal-box { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(0.9); width: 620rpx; background: #1D1D1D; border-radius: 40rpx; padding: 60rpx; z-index: 201; box-sizing: border-box; text-align: center; border: 2rpx solid rgba(255,255,255,0.1); opacity: 0; visibility: hidden; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
.trl-modal-box.show { transform: translate(-50%, -50%) scale(1); opacity: 1; visibility: visible; }
.trl-modal-title { font-family: 'Hiragino Sans GB', sans-serif; font-size: 38rpx; font-weight: 700; color: #FF9811; margin-bottom: 30rpx; display: block; }
.trl-modal-content { font-family: 'PingFang SC', sans-serif; font-size: 28rpx; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 60rpx; display: block; white-space: pre-line; }
.trl-modal-btns { display: flex; gap: 30rpx; }
.trl-btn-primary, .trl-btn-secondary { flex: 1; height: 90rpx; border-radius: 45rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 700; transition: all 0.2s ease; }
.trl-btn-primary { background: #FF9811; color: #000; box-shadow: 0 4rpx 15rpx rgba(255, 152, 17, 0.3); }
.trl-btn-secondary { background: rgba(255, 255, 255, 0.1); color: #FFF; }
.full-width { flex: none !important; width: 100% !important; }
.trl-btn-primary:active, .trl-btn-secondary:active { transform: scale(0.97); opacity: 0.8; }
.text-green { color: #36E153 !important; }
<view class="plan-page">
  <view class="top-nav">
    <view class="back-btn" bindtap="goBack"><view class="arrow-left"></view></view>
  </view>

  <scroll-view class="plan-scroll" scroll-y>
    
    <view class="scroll-top-section">
      <view class="title-group">
        <view class="race-name">{{pureRaceName || raceName}}</view>
        <view class="plan-group-tag" wx:if="{{groupDist}}" style="color: {{groupColor}}; border-color: {{groupColor}};">{{groupDist}}</view>
      </view>
    </view>

    <view class="sticky-and-list-wrapper">
      
      <view class="sticky-wrapper">
        <view class="config-grid-wrapper">
          <view class="config-grid">
            <view class="config-item">
              <text class="config-label">计划用时</text>
              <picker class="config-picker" mode="multiSelector" range="{{timeRange}}" value="{{timeIndex}}" bindchange="onTimeChange">
                <view class="config-capsule"><text>{{targetHours}}h {{targetMinutes}}m</text></view>
              </picker>
            </view>
            <view class="config-item">
              <text class="config-label">发枪时间</text>
              <picker class="config-picker" mode="selector" range="{{availableStartTimes}}" disabled="{{availableStartTimes.length <= 1}}" bindchange="onStartChange">
                <view class="config-capsule" style="{{availableStartTimes.length <= 1 ? 'opacity: 0.7;' : ''}}"><text>{{startTime}}</text></view>
              </picker>
            </view>
            <view class="config-item">
              <text class="config-label">平均休息</text>
              <picker class="config-picker" mode="selector" range="{{restRange}}" value="{{restIndex}}" bindchange="onRestChange">
                <view class="config-capsule"><text>{{globalRestMins}}m</text></view>
              </picker>
            </view>
            <view class="config-item">
              <text class="config-label">补给提示</text>
              <picker class="config-picker" mode="selector" range="{{nutritionRange}}" value="{{nutritionIndex}}" bindchange="onNutritionChange">
                <view class="config-capsule"><text>{{nutritionVal}}</text></view>
              </picker>
            </view>
          </view>
        </view>
      </view>

      <view class="effort-toggle-row" bindtap="toggleEffortPanel">
          <view class="effort-toggle-copy">
            <text class="effort-toggle-title">Physiological & Effort Factors</text>
            <text class="effort-toggle-sub">{{showEffortPanel ? '收起专业调参' : '展开专业调参'}}</text>
          </view>
          <view class="effort-toggle-arrow {{showEffortPanel ? 'expanded' : ''}}"></view>
        </view>

      <view class="effort-panel" wx:if="{{showEffortPanel}}">
        <view class="strategy-card">
          <view class="strategy-head">
            <view>
              <view class="strategy-title-row">
                <text class="strategy-title">配速策略</text>
                <view class="factor-help-btn strategy-help-btn" bindtap="showStrategyHelp">
                  <text>?</text>
                </view>
              </view>
              <text class="strategy-sub">{{strategyModeLabel}} · {{strategyModeDetail}}</text>
            </view>
            <view class="strategy-reset" bindtap="resetPaceStrategy">重置</view>
          </view>

          <view class="strategy-metrics">
            <view class="strategy-metric">
              <view class="strategy-metric-main">
                <text class="strategy-metric-value strategy-metric-fast">{{strategyFastestPace}}</text>
              </view>
              <text class="strategy-metric-label">最快等强配速</text>
            </view>
            <view class="strategy-metric-divider"></view>
            <view class="strategy-metric">
              <view class="strategy-metric-main">
                <text class="strategy-metric-value strategy-metric-slow">{{strategySlowestPace}}</text>
              </view>
              <text class="strategy-metric-label">最慢等强配速</text>
            </view>
          </view>

          <view class="strategy-chart-wrap">
            <image class="strategy-chart-img" wx:if="{{paceStrategyChartSvg}}" src="{{paceStrategyChartSvg}}" mode="widthFix"></image>
          </view>

          <view class="strategy-slider-wrap">
            <slider min="0" max="100" step="1" value="{{paceStrategySlider}}" activeColor="#FFFFFF" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" bindchanging="onStrategySliderChanging" bindchange="onStrategySliderChange" />
            <view class="strategy-slider-labels">
              <text>前快后慢(K+)</text>
              <text>全程匀速(K=1)</text>
              <text>前慢后快(K-)</text>
            </view>
          </view>
        </view>

        <view class="factor-group-card">
          <view class="factor-group-head">
            <view class="factor-group-copy">
              <text class="factor-group-title">Base</text>
              <text class="factor-group-sub">跑走阈值</text>
            </view>
          </view>
          <view class="factor-group-body">
            <view class="factor-row {{effortConfig.base.runHikeThresholdEnabled ? '' : 'factor-row-inactive'}}">
              <view class="factor-row-head">
                <view class="factor-row-title">
                  <text class="factor-label">跑走切换阈值</text>
                  <view class="factor-help-btn" data-group="base" data-field="runHikeThreshold" bindtap="showFactorHelp">
                    <text>?</text>
                  </view>
                </view>
                <view class="factor-row-actions">
                  <text class="factor-value">{{effortConfig.base.runHikeThreshold}}%</text>
                  <switch class="factor-switch" color="#FF9811" checked="{{effortConfig.base.runHikeThresholdEnabled}}" data-group="base" data-field="runHikeThreshold" bindchange="onEffortSwitch" />
                </view>
              </view>
              <slider min="5" max="20" step="1" value="{{effortConfig.base.runHikeThreshold}}" disabled="{{!effortConfig.base.runHikeThresholdEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="base" data-field="runHikeThreshold" bindchange="onEffortSliderChange" />
              <text class="factor-hint">平均坡度高于这个阈值的路段，会更偏向 power hike 分配。</text>
            </view>
          </view>
        </view>

        <view class="factor-group-card">
          <view class="factor-group-head">
            <view class="factor-group-copy">
              <text class="factor-group-title">Physiology</text>
              <text class="factor-group-sub">海拔、夜间</text>
            </view>
          </view>
          <view class="factor-group-body">
            <view class="factor-row {{effortConfig.physiology.altitudePenaltyEnabled ? '' : 'factor-row-inactive'}}">
              <view class="factor-row-head">
                <view class="factor-row-title">
                  <text class="factor-label">高海拔影响</text>
                </view>
                <view class="factor-row-actions switch-only">
                  <switch class="factor-switch" color="#FF9811" checked="{{effortConfig.physiology.altitudePenaltyEnabled}}" data-group="physiology" data-field="altitudePenalty" bindchange="onEffortSwitch" />
                </view>
              </view>
              <view class="factor-pair-stack">
                <view class="factor-sub-row">
                  <view class="factor-sub-head">
                    <view class="factor-sub-title">
                      <text class="factor-sub-label">海拔阈值</text>
                      <view class="factor-help-btn" data-group="physiology" data-field="altitudeThreshold" bindtap="showFactorHelp">
                        <text>?</text>
                      </view>
                    </view>
                    <text class="factor-sub-value">{{effortConfig.physiology.altitudeThreshold}}m</text>
                  </view>
                  <slider min="1000" max="3500" step="100" value="{{effortConfig.physiology.altitudeThreshold}}" disabled="{{!effortConfig.physiology.altitudePenaltyEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="physiology" data-field="altitudeThreshold" bindchange="onEffortSliderChange" />
                </view>
                <view class="factor-sub-divider"></view>
                <view class="factor-sub-row">
                  <view class="factor-sub-head">
                    <view class="factor-sub-title">
                      <text class="factor-sub-label">高海拔惩罚</text>
                      <view class="factor-help-btn" data-group="physiology" data-field="altitudePenalty" bindtap="showFactorHelp">
                        <text>?</text>
                      </view>
                    </view>
                    <text class="factor-sub-value">{{effortConfig.physiology.altitudePenalty}}%</text>
                  </view>
                  <slider min="0" max="20" step="1" value="{{effortConfig.physiology.altitudePenalty}}" disabled="{{!effortConfig.physiology.altitudePenaltyEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="physiology" data-field="altitudePenalty" bindchange="onEffortSliderChange" />
                </view>
              </view>
            </view>
            <view class="factor-row {{effortConfig.physiology.nightPenaltyEnabled ? '' : 'factor-row-inactive'}}">
              <view class="factor-row-head">
                <view class="factor-row-title">
                  <text class="factor-label">夜间惩罚</text>
                  <view class="factor-help-btn" data-group="physiology" data-field="nightPenalty" bindtap="showFactorHelp">
                    <text>?</text>
                  </view>
                </view>
                <view class="factor-row-actions">
                  <text class="factor-value">{{effortConfig.physiology.nightPenalty}}%</text>
                  <switch class="factor-switch" color="#FF9811" checked="{{effortConfig.physiology.nightPenaltyEnabled}}" data-group="physiology" data-field="nightPenalty" bindchange="onEffortSwitch" />
                </view>
              </view>
              <slider min="0" max="15" step="1" value="{{effortConfig.physiology.nightPenalty}}" disabled="{{!effortConfig.physiology.nightPenaltyEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="physiology" data-field="nightPenalty" bindchange="onEffortSliderChange" />
              <view class="factor-time-range">
                <picker mode="selector" range="{{hourOptions}}" value="{{effortConfig.physiology.nightStartHour}}" disabled="{{!effortConfig.physiology.nightPenaltyEnabled}}" data-field="nightStartHour" bindchange="onNightWindowChange">
                  <view class="factor-time-picker {{effortConfig.physiology.nightPenaltyEnabled ? '' : 'factor-time-picker-disabled'}}">
                    <text class="factor-time-label">开始</text>
                    <text class="factor-time-value">{{hourOptions[effortConfig.physiology.nightStartHour]}}</text>
                  </view>
                </picker>
                <text class="factor-time-sep">至</text>
                <picker mode="selector" range="{{hourOptions}}" value="{{effortConfig.physiology.nightEndHour}}" disabled="{{!effortConfig.physiology.nightPenaltyEnabled}}" data-field="nightEndHour" bindchange="onNightWindowChange">
                  <view class="factor-time-picker {{effortConfig.physiology.nightPenaltyEnabled ? '' : 'factor-time-picker-disabled'}}">
                    <text class="factor-time-label">结束</text>
                    <text class="factor-time-value">{{hourOptions[effortConfig.physiology.nightEndHour]}}</text>
                  </view>
                </picker>
              </view>
              <text class="factor-hint">默认按 20:00 到次日 06:00 的夜间窗口处理。</text>
            </view>
          </view>
        </view>

        <view class="factor-group-card">
          <view class="factor-group-head">
            <view class="factor-group-copy">
              <text class="factor-group-title">Terrain Skill</text>
              <text class="factor-group-sub">上坡能力、下坡能力</text>
            </view>
          </view>
          <view class="factor-group-body">
            <view class="factor-row {{effortConfig.terrain.uphillSkillEnabled ? '' : 'factor-row-inactive'}}">
              <view class="factor-row-head">
                <view class="factor-row-title">
                  <text class="factor-label">上坡能力</text>
                  <view class="factor-help-btn" data-group="terrain" data-field="uphillSkill" bindtap="showFactorHelp">
                    <text>?</text>
                  </view>
                </view>
                <view class="factor-row-actions">
                  <text class="factor-value">{{effortConfig.terrain.uphillSkill}}%</text>
                  <switch class="factor-switch" color="#FF9811" checked="{{effortConfig.terrain.uphillSkillEnabled}}" data-group="terrain" data-field="uphillSkill" bindchange="onEffortSwitch" />
                </view>
              </view>
              <slider min="80" max="120" step="1" value="{{effortConfig.terrain.uphillSkill}}" disabled="{{!effortConfig.terrain.uphillSkillEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="terrain" data-field="uphillSkill" bindchange="onEffortSliderChange" />
            </view>
            <view class="factor-row {{effortConfig.terrain.downhillSkillEnabled ? '' : 'factor-row-inactive'}}">
              <view class="factor-row-head">
                <view class="factor-row-title">
                  <text class="factor-label">下坡能力</text>
                  <view class="factor-help-btn" data-group="terrain" data-field="downhillSkill" bindtap="showFactorHelp">
                    <text>?</text>
                  </view>
                </view>
                <view class="factor-row-actions">
                  <text class="factor-value">{{effortConfig.terrain.downhillSkill}}%</text>
                  <switch class="factor-switch" color="#FF9811" checked="{{effortConfig.terrain.downhillSkillEnabled}}" data-group="terrain" data-field="downhillSkill" bindchange="onEffortSwitch" />
                </view>
              </view>
              <slider min="80" max="120" step="1" value="{{effortConfig.terrain.downhillSkill}}" disabled="{{!effortConfig.terrain.downhillSkillEnabled}}" activeColor="#FF9811" backgroundColor="rgba(255,255,255,0.12)" block-color="#FFFFFF" block-size="18" data-group="terrain" data-field="downhillSkill" bindchange="onEffortSliderChange" />
            </view>
          </view>
        </view>

        <view class="effort-collapse-footer">
          <view class="effort-collapse-btn" bindtap="toggleEffortPanel">
            <text>收起</text>
          </view>
        </view>
      </view>

      <view class="list-header-container">
        <view class="list-row-inner">
          <view class="col-1"><text class="lh-text">地点</text></view>
          <view class="col-2">
            <text class="lh-main">计划用时(m)</text>
            <text class="lh-sub">(平均等强)</text>
          </view>
          <view class="col-3">
            <text class="lh-main">休息(m)</text>
            <text class="lh-sub">(到达时间)</text>
          </view>
          <view class="col-4"><text class="lh-text">海拔图</text></view>
          <view class="col-5"><text class="lh-text">赛道信息</text></view>
        </view>
      </view>

      <view class="list-content">
        <view class="cp-row list-row-inner" wx:for="{{checkpoints}}" wx:key="index" wx:if="{{index > 0}}" bindtap="goToSegmentDetail" data-index="{{index}}">
          
          <view class="col-1">
            <text class="cp-name">{{item.cpNum}}</text>
            <text class="dp-tag" wx:if="{{item.isDropBag}}">换装点</text>
            <text class="cutoff-text" wx:if="{{item.displayCutoffTime && item.displayCutoffTime !== '--:--'}}">{{item.displayCutoffTime}}关门</text>
          </view>

          <view class="col-2" catchtap="preventTouchMove">
            <view class="ctrl-box">
              <input class="{{item.isOvertime ? 'text-red' : 'text-orange'}}" type="number" value="{{item.moveMins}}" data-index="{{index}}" data-type="move" bindblur="onManualUpdate" />
            </view>
            <text class="sub-label">({{item.eqPaceShort}})</text>
          </view>

          <view class="col-3" catchtap="preventTouchMove">
            <view class="ctrl-box" wx:if="{{index < checkpoints.length - 1}}">
              <input class="text-blue" type="number" value="{{item.rest}}" data-index="{{index}}" data-type="rest" bindblur="onManualUpdate" />
            </view>
            <view class="ctrl-box" wx:else style="visibility: hidden;"></view>
            <text class="sub-label {{item.isOvertime ? 'text-red' : ''}}">({{item.arrTime}})</text>
          </view>

          <view class="col-4">
            <view class="elevation-svg" wx:if="{{item.svgProfile}}" style="background-image: url('{{item.svgProfile}}');"></view>
          </view>
          
          <view class="col-5 stats">
            <view class="dist-val">{{item.segDist}}KM</view>
            <view class="gain-loss">
              <text class="val-up">+{{item.segGain}}</text>
              <text class="val-down">-{{item.segLoss}}</text>
            </view>
          </view>

          <view class="row-divider"></view>
        </view>

        <view class="bottom-action-bar">
          <view class="btn btn-save" bindtap="savePlanImage">保存图片</view>
          <view class="btn btn-sync" bindtap="syncToHardware">同步至手表</view>
        </view>
        <view style="height: 80rpx;"></view> 
      </view>

    </view> 
  </scroll-view>

  <view class="modal-mask" wx:if="{{showDetail}}" bindtap="closeDetail" catchtouchmove="preventTouchMove"></view>
  
  <view class="detail-sheet {{showDetail ? 'show' : ''}}">
    <view class="ds-drag-area" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd" data-type="dragArea" catchtouchmove="preventTouchMove">
      <view class="pull-handle"></view>
      <view class="ds-top-bar">
        <view class="ds-close-circle" bindtap="closeDetail">
          <view class="ds-cross1"></view>
          <view class="ds-cross2"></view>
        </view>
        <view class="ds-total-capsule">
          <text>计划总用时:{{targetHours}}h {{targetMinutes}}min</text>
        </view>
      </view>
    </view>

    <swiper class="detail-swiper" current="{{detailCurrent}}" bindchange="onDetailSwiperChange">
      <swiper-item wx:for="{{checkpoints}}" wx:key="index" wx:if="{{index > 0}}">
        <scroll-view class="ds-scroll" scroll-y bindscroll="onScroll" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd" data-type="scrollView">
          <view class="ds-title-row">
            <view class="ds-title-main">
              <text class="ds-cp-main">{{item.cpNum}}</text>
              <text class="ds-cp-sub" wx:if="{{item.locName}}">{{item.locName}}</text>
            </view>
            <view class="ds-title-meta">
              <text class="ds-title-meta-lbl">关门时间</text>
              <text class="ds-title-meta-val {{item.isOvertime ? 'text-red' : ''}}">{{item.displayCutoffTime || item.cutoffTime || '--:--'}}</text>
            </view>
          </view>
          <view class="ds-title-divider"></view>

          <view class="ds-stats-header">
            <view class="ds-stats-left">
              <text class="ds-dist-large">{{item.segDist}}km</text>
              <text class="ds-elev-up">↑{{item.segGain}}m</text>
              <text class="ds-elev-down">↓{{item.segLoss}}m</text>
            </view>
            <view class="ds-stats-right">
              <view class="ds-grade-toggle {{detailGradeMode ? 'active' : ''}}" bindtap="toggleDetailGradeMode">
                <text>{{detailGradeMode ? '关闭坡度' : '显示坡度'}}</text>
              </view>
            </view>
          </view>

          <view class="ds-chart-area">
            <canvas type="2d" id="elevChart_{{index}}" class="elev-canvas"
                    catchtouchstart="onChartTouch" catchtouchmove="onChartTouch" catchtouchend="onChartTouchEnd"></canvas>
            <view class="chart-loading" wx:if="{{!chartReady[index]}}">正在渲染地形雷达...</view>
          </view>

          <view class="ds-grid">
            <view class="ds-grid-row">
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">总距离</text>
                <text class="ds-cell-val">{{checkpoints[index-1].accDist}}km-{{item.accDist}}km</text>
              </view>
              <view class="ds-grid-gap"></view>
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">等强距离</text>
                <text class="ds-cell-val">{{item.eqDist}}KM</text>
              </view>
            </view>
            <view class="ds-grid-row">
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">平均配速</text>
                <text class="ds-cell-val">{{item.pace}}</text>
              </view>
              <view class="ds-grid-gap"></view>
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">平均等强配速</text>
                <text class="ds-cell-val">{{item.eqPace}}</text>
              </view>
            </view>
            <view class="ds-grid-row">
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">计划到达</text>
                <text class="ds-cell-val {{item.isOvertime ? 'text-red' : ''}}">{{item.arrTime}}</text>
              </view>
              <view class="ds-grid-gap"></view>
              <view class="ds-grid-cell">
                <text class="ds-cell-lbl">计划离开</text>
                <text class="ds-cell-val">{{item.depTime}}</text>
              </view>
            </view>
          </view>

          <view class="ds-inputs-row">
            <view class="ds-input-col">
              <text class="ds-input-lbl">计划用时</text>
              <view class="ds-input-capsule">
                <input class="{{item.isOvertime ? 'text-red' : 'txt-orange'}}" type="number" value="{{item.moveMins}}" data-index="{{index}}" data-type="move" bindblur="onManualUpdate" />
                <text class="ds-unit {{item.isOvertime ? 'text-red' : 'txt-orange'}}">min</text>
              </view>
            </view>
            <view class="ds-input-col">
              <text class="ds-input-lbl">休息时间</text>
              <view class="ds-input-capsule">
                <input class="txt-blue" type="number" value="{{item.rest}}" data-index="{{index}}" data-type="rest" bindblur="onManualUpdate" />
                <text class="txt-blue ds-unit">min</text>
              </view>
            </view>
          </view>

          <view class="ds-divider"></view>
          <view class="ds-memo-wrapper">
            <text class="ds-input-lbl" style="text-align: left;">休息备忘录</text>
            <view class="ds-memo-box">
              <textarea value="{{item.memo}}" data-index="{{index}}" bindinput="onMemoInput" placeholder="点击添加备忘 (例如: 吃盐丸、换袜子)..." placeholder-class="ph-color" cursor-spacing="40" />
            </view>
          </view>
          <view style="height: 120rpx;"></view>
        </scroll-view>
      </swiper-item>
    </swiper>
  </view>

  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>

  <view class="custom-modal-mask" wx:if="{{showConnectModal || showSuccessModal || showUnsavedModal}}" catchtouchmove="preventTouchMove"></view>
  
  <view class="trl-modal-box {{showConnectModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <text class="trl-modal-title">设备未连接</text>
    <text class="trl-modal-content">当前未连接手表。\n您可以去连接设备，或者仅将计划上传至云端库。</text>
    <view class="trl-modal-btns">
      <view class="trl-btn-secondary" bindtap="modalLocalSave">仅存云端</view>
      <view class="trl-btn-primary" bindtap="modalGoConnect">去连接</view>
    </view>
  </view>

  <view class="trl-modal-box {{showSuccessModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <text class="trl-modal-title text-green">操作成功</text>
    <text class="trl-modal-content">{{successModalTitle}}\n路书数据已就绪，祝您安全完赛！🚀</text>
    <view class="trl-modal-btns">
      <view class="trl-btn-primary full-width" bindtap="modalBackToHome">返回主页</view>
    </view>
  </view>

  <view class="trl-modal-box {{showUnsavedModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <text class="trl-modal-title">未保存提示</text>
    <text class="trl-modal-content">当前专属计划尚未保存，退出将丢失本次修改内容。\n是否立即保存并同步？</text>
    <view class="trl-modal-btns">
      <view class="trl-btn-secondary" bindtap="modalDiscardAndExit">直接退出</view>
      <view class="trl-btn-primary" bindtap="modalSaveAndSync">保存并同步</view>
    </view>
  </view>

</view>

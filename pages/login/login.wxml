<view class="login-page">
  <view class="back-btn" bindtap="goBack"><view class="arrow-left"></view></view>
  
  <view class="header-titles">
    <text class="main-title">AST SYSTEM</text>
    <text class="sub-title">硬核越野数据中枢</text>
  </view>

  <view class="tab-box">
    <view class="tab {{isLoginMode ? 'active' : ''}}" bindtap="switchMode" data-mode="login">登录</view>
    <view class="tab {{!isLoginMode ? 'active' : ''}}" bindtap="switchMode" data-mode="register">注册</view>
  </view>

  <view class="form-box">
    <view class="input-group">
      <text class="label">账号名称</text>
      <input class="input-field" placeholder="请输入专属代号" placeholder-class="ph-style" model:value="{{username}}" />
    </view>
    
    <view class="input-group">
      <text class="label">访问密码</text>
      <input class="input-field" password="true" placeholder="请输入密钥" placeholder-class="ph-style" model:value="{{password}}" />
    </view>
  </view>

  <view class="submit-btn" bindtap="handleSubmit">
    {{isLoginMode ? '验证身份 / LOGIN' : '创建档案 / REGISTER'}}
  </view>
</view>
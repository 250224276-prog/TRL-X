page { background: #000000; color: #FFFFFF; font-family: 'Inter', sans-serif; }
.login-page { padding: 100rpx 60rpx; display: flex; flex-direction: column; height: 100vh; box-sizing: border-box; }

.back-btn { width: 60rpx; height: 60rpx; margin-bottom: 80rpx; }
.arrow-left { width: 24rpx; height: 24rpx; border-left: 4rpx solid #FFF; border-bottom: 4rpx solid #FFF; transform: rotate(45deg); }

.header-titles { margin-bottom: 80rpx; display: flex; flex-direction: column; }
.main-title { font-size: 64rpx; font-weight: 900; letter-spacing: 2rpx; color: #FF9849; }
.sub-title { font-size: 28rpx; color: #888; margin-top: 10rpx; letter-spacing: 4rpx; }

/* 登录/注册切换标签 */
.tab-box { display: flex; margin-bottom: 60rpx; border-bottom: 2rpx solid rgba(255,255,255,0.1); }
.tab { font-size: 32rpx; font-weight: 700; color: #666; padding-bottom: 20rpx; margin-right: 60rpx; position: relative; transition: all 0.3s; }
.tab.active { color: #FFF; }
.tab.active::after { content: ''; position: absolute; bottom: -2rpx; left: 0; width: 100%; height: 6rpx; background: #FF9849; border-radius: 4rpx; }

/* 表单输入区 */
.form-box { margin-bottom: 80rpx; }
.input-group { margin-bottom: 40rpx; }
.label { font-size: 24rpx; color: #888; margin-bottom: 16rpx; display: block; font-weight: 700; }
.input-field { width: 100%; height: 90rpx; background: rgba(255,255,255,0.05); border-radius: 16rpx; padding: 0 30rpx; font-size: 32rpx; color: #FFF; box-sizing: border-box; border: 2rpx solid transparent; transition: border 0.3s; }
.input-field:focus { border-color: #FF9849; background: rgba(255,152,73,0.05); }
.ph-style { color: #444; }

/* 提交按钮 */
.submit-btn { width: 100%; height: 100rpx; background: #FF9849; color: #000; border-radius: 50rpx; display: flex; justify-content: center; align-items: center; font-size: 32rpx; font-weight: 900; letter-spacing: 2rpx; box-shadow: 0 10rpx 30rpx rgba(255,152,73,0.3); transition: transform 0.1s; }
.submit-btn:active { transform: scale(0.98); }
/* ========================================== */
/* 全局背景 */
/* ========================================== */
.container {
  min-height: 100vh;
  background-color: #000000;
  padding: 0 40rpx 200rpx 40rpx;
  box-sizing: border-box;
  color: #FFFFFF;
}

/* ========================================== */
/* 1. 顶部自定义导航 */
/* ========================================== */
.custom-nav {
  height: 180rpx;
  display: flex;
  align-items: flex-end;
  padding-bottom: 20rpx;
  position: relative;
}
.back-btn {
  width: 20rpx;
  height: 20rpx;
  border-bottom: 4rpx solid #FFFFFF;
  border-left: 4rpx solid #FFFFFF;
  transform: rotate(45deg);
  margin-bottom: 10rpx;
  padding: 10rpx;
}
.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Inter', sans-serif;
  font-weight: 600;
  font-size: 36rpx;
}

/* ========================================== */
/* 2. 顶部赛事信息卡片 */
/* ========================================== */
.header-card {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.11);
  border-radius: 44rpx;
  padding: 30rpx;
  display: flex;
  gap: 30rpx;
}
.race-cover {
  width: 220rpx;
  height: 220rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
}
.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.info-top {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.race-date {
  font-size: 24rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.6);
  text-align: left;
}
.race-name {
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 36rpx;
  color: #FF9811;
}
.info-bottom {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
}
.itra-tag {
  font-size: 20rpx;
  color: #FF9811;
  font-weight: 500;
}
.race-location {
  font-size: 20rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}

/* ========================================== */
/* 3. 组别选择器 (带有滑动光块) */
/* ========================================== */
.distance-selector {
  margin-top: 40rpx;
  width: 600rpx; 
  height: 68rpx;
  background: rgba(255, 255, 255, 0.08); 
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  position: relative; 
  overflow: hidden; 
}

.dist-slider-bg {
  position: absolute;
  height: 100%;
  left: 0;
  top: 0;
  background: rgba(255, 255, 255, 0.15); 
  border-radius: 34rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 1; 
}

.dist-btn {
  flex: 1; 
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: 'PingFang SC', sans-serif;
  font-size: 32rpx; 
  font-weight: 600; 
  position: relative;
  z-index: 2;
  transition: opacity 0.3s ease;
}

/* ========================================== */
/* 4. Tab 切换面板 (带有滑动光块) */
/* ========================================== */
.tab-switcher {
  margin-top: 30rpx;
  width: 400rpx; 
  height: 68rpx; 
  background: rgba(255, 255, 255, 0.08); 
  border-radius: 34rpx; 
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.tab-slider-bg {
  position: absolute;
  width: 50%; 
  height: 100%;
  left: 0;
  top: 0;
  background: rgba(255, 255, 255, 0.15); 
  border-radius: 34rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 1;
}

.tab-item {
  flex: 1; 
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: 'Hiragino Sans GB', sans-serif;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  opacity: 0.5;
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
}

.tab-item.active {
  opacity: 1;
}

/* ========================================== */
/* 5. 内容区：比赛详细 */
/* ========================================== */
.content-detail {
  margin-top: 40rpx;
}
.section-title {
  font-family: 'Hiragino Sans GB', sans-serif;
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.key-data-card {
  background: rgba(255, 255, 255, 0.11);
  border-radius: 32rpx;
  padding: 10rpx 40rpx; 
  margin-bottom: 50rpx;
}
.data-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0; 
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}
.data-row.border-none {
  border-bottom: none; 
}
.data-label {
  font-size: 26rpx; 
  font-weight: 500;
  color: rgba(255, 255, 255, 0.6); 
}
.data-value {
  font-size: 28rpx; 
  font-weight: 600;
}

.detail-map {
  width: 100%;
  border-radius: 32rpx; 
  background: rgba(255, 255, 255, 0.1);
  margin-bottom: 50rpx;
}

/* ========================================== */
/* 6. 内容区：制定计划 */
/* ========================================== */
.content-plan {
  margin-top: 40rpx;
  min-height: 500rpx;
}

.time-input-card {
  background: rgba(255, 255, 255, 0.11);
  border-radius: 44rpx;
  padding: 60rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx; 
}
.input-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.input-wrap input {
  width: 160rpx;
  height: 140rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 28rpx;
  text-align: center;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
  font-size: 60rpx;
  color: #FFFFFF;
}
.ph-color {
  color: rgba(255, 255, 255, 0.2);
}
.unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
.divider {
  font-family: 'Inter', sans-serif;
  font-size: 50rpx;
  color: rgba(255, 255, 255, 0.3);
  margin: 0 40rpx;
  margin-top: -50rpx; 
}

/* ✨ 发枪时间胶囊阵列 */
.capsule-container {
  display: flex;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 40rpx;
  height: 80rpx;
  width: 100%;
  position: relative;
  overflow: hidden;
  margin-bottom: 120rpx;
}

.capsule-slider-bg {
  position: absolute;
  height: 100%;
  top: 0;
  left: 0;
  background: rgba(255, 255, 255, 0.15); 
  border-radius: 40rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  z-index: 1;
}

.capsule-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  font-family: 'Inter', sans-serif;
  color: rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
}
.capsule-item.active {
  color: #FFFFFF;
}

/* 底部悬浮按钮 */
.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(to top, rgba(0,0,0,1) 60%, rgba(0,0,0,0));
  box-sizing: border-box;
  z-index: 10;
}
.generate-btn {
  width: 100%;
  height: 110rpx;
  background: #FF9811;
  color: #000000;
  font-family: 'PingFang HK', sans-serif;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 55rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(255, 152, 17, 0.2);
  transition: all 0.2s ease;
}
.generate-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}